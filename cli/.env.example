# SafePassage CLI environment variables. Copy to .env and fill in.
# .env is gitignored. NEVER commit real values.

# Network: preprod | mainnet | standalone. Defaults to preprod.
NETWORK=preprod

# Proof server URL (Docker container, port 6300 by default).
PROOF_SERVER=http://localhost:6300

# Password used to encrypt the level-private-state-provider's on-disk store.
# Generate with: openssl rand -base64 24
MIDNIGHT_STORAGE_PASSWORD=replace-with-rand-base64-24-string

# 24-word BIP39 seed phrase for the admin wallet that funds the pool,
# deploys the contract, registers codes, and sets service routes.
#
# Use the seed phrase from your FRESH Lace demo wallet (never a personal
# seed). The CLI derives the same NIGHT/DUST balances Lace shows.
# This file is gitignored; the seed is never committed.
#
# Get the seed from Lace: Settings -> Wallet -> Recovery Phrase.
MIDNIGHT_SEED_PHRASE="paste twenty four words here separated by single spaces"
